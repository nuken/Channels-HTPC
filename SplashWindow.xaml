<Window x:Class="FeralCode.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starting..." Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">
    
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#007ACC" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="8" Opacity="0.6"/>
        </Border.Effect>
        
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="FERAL HTPC" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock Text="Waking up the server..." FontSize="16" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <ProgressBar IsIndeterminate="True" Width="250" Height="4" Foreground="#007ACC" Background="#333333" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>